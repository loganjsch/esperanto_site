          <rect x="152" y="48" width="10" height="262" fill="url(#beam-grad)" filter="url(#beam-glow)" opacity="0.7"/>

          <!-- ── Layer: Applications ── -->
          <polygon points="157,48 237,68 157,88 77,68"   fill="rgba(37,99,255,0.04)" stroke="rgba(37,99,255,0.14)" stroke-width="1"/>
          <polygon points="237,68 237,82 157,102 157,88"  fill="rgba(0,0,0,0.18)"  stroke="rgba(37,99,255,0.09)" stroke-width="1"/>
          <polygon points="77,68  77,82  157,102 157,88"  fill="rgba(0,0,0,0.12)"  stroke="rgba(37,99,255,0.07)" stroke-width="1"/>
          <text x="244" y="74"  font-family="monospace" font-size="11" style="fill:var(--text-muted)" opacity="0.6">Applications</text>

          <!-- ── Layer: Kernel ── -->
          <polygon points="157,112 237,132 157,152 77,132"  fill="rgba(37,99,255,0.06)" stroke="rgba(37,99,255,0.2)"  stroke-width="1"/>
          <polygon points="237,132 237,146 157,166 157,152" fill="rgba(0,0,0,0.22)"  stroke="rgba(37,99,255,0.13)" stroke-width="1"/>
          <polygon points="77,132  77,146  157,166 157,152" fill="rgba(0,0,0,0.15)"  stroke="rgba(37,99,255,0.1)"  stroke-width="1"/>
          <text x="244" y="138" font-family="monospace" font-size="11" style="fill:var(--text-muted)" opacity="0.75">Kernel</text>

          <!-- ── Layer: Bootloader ── -->
          <polygon points="157,176 237,196 157,216 77,196"  fill="rgba(37,99,255,0.08)" stroke="rgba(37,99,255,0.28)" stroke-width="1"/>
          <polygon points="237,196 237,210 157,230 157,216" fill="rgba(0,0,0,0.26)"  stroke="rgba(37,99,255,0.18)" stroke-width="1"/>
          <polygon points="77,196  77,210  157,230 157,216" fill="rgba(0,0,0,0.18)"  stroke="rgba(37,99,255,0.14)" stroke-width="1"/>
          <text x="244" y="202" font-family="monospace" font-size="11" style="fill:var(--text-muted)">Bootloader</text>

