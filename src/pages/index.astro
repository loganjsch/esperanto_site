<script>
// ── Theme toggle ────────────────────────────────────────────
const html   = document.documentElement;
const toggle = document.getElementById('theme-toggle')!;
const sun    = document.getElementById('icon-sun')!;
const moon   = document.getElementById('icon-moon')!;

function setTheme(light: boolean) {
  html.setAttribute('data-theme', light ? 'light' : 'dark');
  sun.style.display  = light ? 'block' : 'none';
  moon.style.display = light ? 'none'  : 'block';
  localStorage.setItem('theme', light ? 'light' : 'dark');
}

const saved = localStorage.getItem('theme');
setTheme(saved === 'light');
toggle.addEventListener('click', () => setTheme(html.getAttribute('data-theme') !== 'light'));

// ── Fleet grid ──────────────────────────────────────────────
const FLEET = 144;
const grid  = document.getElementById('fleet-grid');
const nodes: { el: HTMLElement; state: string }[] = [];

for (let i = 0; i < FLEET; i++) {
  const el = document.createElement('div');
  el.className = 'fn trusted';
  grid!.appendChild(el);
  nodes.push({ el, state: 'trusted' });
}

function updateHeader() {
  const failed    = nodes.filter(n => n.state === 'failed').length;
  const verifying = nodes.filter(n => n.state === 'verifying').length;
  const trusted   = FLEET - failed - verifying;
  document.getElementById('fleet-trusted')!.textContent = trusted + ' TRUSTED';
  const statusEl = document.getElementById('fleet-status')!;
  if (failed > 0) {
    statusEl.textContent = failed + ' FAILED';
    statusEl.style.color = '#ff5050';
  } else {
    statusEl.textContent = verifying + ' VERIFYING';
    statusEl.style.color = '#f5c43c';
  }
}

function tick() {
  const pool = nodes.filter(n => n.state === 'trusted');
  if (!pool.length) return;
  const node = pool[Math.floor(Math.random() * pool.length)];
  node.state = 'verifying';
  node.el.className = 'fn verifying';
  updateHeader();
  const fail = Math.random() < 0.06;
  setTimeout(() => {
    if (fail) {
      node.state = 'failed';
      node.el.className = 'fn failed';
      updateHeader();
      setTimeout(() => { node.state = 'trusted'; node.el.className = 'fn trusted'; updateHeader(); }, 2800 + Math.random() * 1800);
    } else {
      node.state = 'trusted';
      node.el.className = 'fn trusted';
      updateHeader();
    }
  }, 700 + Math.random() * 500);
}

updateHeader();
nodes.forEach((n, i) => {
  if (Math.random() < 0.08) {
    n.state = 'verifying'; n.el.className = 'fn verifying';
    setTimeout(() => { n.state = 'trusted'; n.el.className = 'fn trusted'; updateHeader(); }, 800 + i * 12);
  }
});
setInterval(tick, 180);

// ── Scroll reveal ───────────────────────────────────────────
const obs = new IntersectionObserver(
  entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); }),
  { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
);
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

document.querySelectorAll('.install-pm-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.install-pm-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const distro = document.getElementById('install-distro');
    if (btn.dataset.os === 'linux') {
      distro.classList.add('visible');
      const active = distro.querySelector('.install-distro-btn.active');
      document.getElementById('install-cmd').textContent = active ? active.dataset.cmd : '';
    } else {
      distro.classList.remove('visible');
      document.getElementById('install-cmd').textContent = btn.dataset.cmd;
    }
  });
});

// Show distro sub-buttons by default since Linux is the default tab
document.getElementById('install-distro').classList.add('visible');

document.querySelectorAll('.install-distro-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.install-distro-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('install-cmd').textContent = btn.dataset.cmd;
  });
});

document.getElementById('install-copy').addEventListener('click', () => {
  const cmd = document.getElementById('install-cmd').textContent;
  navigator.clipboard.writeText(cmd).then(() => {
    const btn = document.getElementById('install-copy');
    const orig = btn.innerHTML;
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9l4 4L14 4"/></svg>';
    setTimeout(() => btn.innerHTML = orig, 1800);
  });
});
</script>

