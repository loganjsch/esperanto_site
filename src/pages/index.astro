---
// icon helper — stroke-based SVG, consistent with Lucide
const ico = (d: string, size = 18) =>
  `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;

// ── icons ────────────────────────────────────────────────────
const LOCK     = `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`;
const ZAP      = `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`;
const GIT      = `<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>`;
const SERVER   = `<rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`;
const SHIELD   = `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`;
const FILECK   = `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><polyline points="9 15 11 17 15 13"/>`;
const SEARCH   = `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`;
const ALERT    = `<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`;
const LAYERS   = `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`;
const KEY      = `<path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>`;
const EDIT     = `<path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>`;
const TERM     = `<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>`;
const NETWORK  = `<rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><line x1="12" y1="12" x2="12" y2="8"/>`;
// trust chain
const CPU      = `<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2m0 18v2M2 15h2m18 0h2M2 9h2m18 0h2M9 2v2m0 18v2"/>`;
const KEYSMALL = `<circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2l-9.6 9.6"/><path d="M15.5 7.5l3 3L22 7l-3-3"/>`;
const BADGE    = `<rect x="2" y="7" width="20" height="15" rx="2"/><polyline points="16 2 12 6 8 2"/>`;
const BARCHART = `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`;
const HASH     = `<line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/>`;
const LIST     = `<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>`;
const FILETXT  = `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`;
const EDITSMALL= `<path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>`;
const DATABASE = `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>`;
const TICKET   = `<path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>`;
const BUILDING = `<rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><line x1="8" y1="6" x2="8.01" y2="6"/><line x1="16" y1="6" x2="16.01" y2="6"/><line x1="12" y1="6" x2="12.01" y2="6"/><line x1="12" y1="10" x2="12.01" y2="10"/><line x1="8" y1="10" x2="8.01" y2="10"/><line x1="16" y1="10" x2="16.01" y2="10"/><line x1="8" y1="14" x2="8.01" y2="14"/><line x1="16" y1="14" x2="16.01" y2="14"/><line x1="12" y1="14" x2="12.01" y2="14"/>`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ratatouille — Remote ATTestation</title>
  <meta name="description" content="Continuously verify every machine in your fleet against a signed policy — via TPM quote and IMA log, every ~10 seconds. TRUSTED or it isn't." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #04060f;
      --bg-surface:   #080d1c;
      --bg-card:      #0c1228;
      --bg-card-hov:  #101830;
      --border:       #141e3a;
      --border-bright:#1e2e55;
      --green:        #2563ff;
      --green-dim:    #1a4fd6;
      --green-faint:  #0f2e8a;
      --green-glow:   rgba(37,99,255,.12);
      --green-glow2:  rgba(37,99,255,.26);
      --text:         #d6e0f5;
      --text-muted:   #6880b8;
      --text-dim:     #4a5c9a;
      --font:         'Inter', system-ui, -apple-system, sans-serif;
      --mono:         'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
      --r:            8px;
      --r-lg:         14px;
    }

    [data-theme="light"] {
      --bg:           #f2f4f9;
      --bg-surface:   #e8ecf5;
      --bg-card:      #edf0f8;
      --bg-card-hov:  #e3e8f2;
      --border:       #cdd4e8;
      --border-bright:#b0bcd8;
      --green:        #1a4fd6;
      --green-dim:    #1440b8;
      --green-faint:  #0d2d80;
      --green-glow:   rgba(26,79,214,.10);
      --green-glow2:  rgba(26,79,214,.20);
      --text:         #0d1224;
      --text-muted:   #3a4e7a;
      --text-dim:     #7a8fbb;
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 16px;
      line-height: 1.65;
      overflow-x: hidden;
      transition: background .25s, color .25s;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, rgba(37,99,255,.06) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none;
      z-index: 0;
      transition: background-image .3s;
    }
    [data-theme="light"] body::before {
      background-image: radial-gradient(circle, rgba(37,99,255,.07) 1px, transparent 1px);
    }

    h1,h2,h3 { font-weight: 700; line-height: 1.15; letter-spacing: -0.025em; }
    h1 { font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 900; }
    h2 { font-size: clamp(1.7rem, 3.5vw, 2.6rem); }
    h3 { font-size: 1.05rem; font-weight: 600; }
    p  { color: var(--text-muted); }
    a  { color: var(--green); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .container { max-width: 1140px; margin: 0 auto; padding: 0 28px; position: relative; z-index: 1; }
    .section    { padding: 100px 0; }
    .section-sm { padding: 72px 0; }

    .tag {
      display: inline-block;
      font-family: var(--mono);
      font-size: 0.67rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--green);
      background: var(--green-glow);
      border: 1px solid rgba(37,99,255,.18);
      padding: 4px 10px;
      border-radius: 4px;
      margin-bottom: 1.2rem;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0; z-index: 100;
      background: rgba(4,8,7,.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      transition: background .25s, border-color .25s;
    }
    [data-theme="light"] nav { background: rgba(242,245,243,.93); }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px; max-width: 1140px; margin: 0 auto; height: 58px;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 0;
      font-size: 1.1rem; font-weight: 900;
      letter-spacing: -0.03em; text-decoration: none;
    }
    .nav-logo .rat  { color: var(--green); }
    .nav-logo .rest { color: var(--text); }
    .nav-links { display: flex; align-items: center; gap: 32px; list-style: none; }
    .nav-links a {
      color: var(--text-muted); font-size: 0.875rem; font-weight: 500;
      transition: color .18s; text-decoration: none;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-cta {
      background: var(--green) !important; color: #ffffff !important;
      padding: 7px 18px; border-radius: var(--r);
      font-weight: 700 !important; font-size: 0.85rem !important;
      transition: background .18s, transform .15s;
    }
    .nav-cta:hover { background: var(--green-dim) !important; transform: translateY(-1px); text-decoration: none !important; }

    /* ── HERO ── */
    .hero {
      min-height: 86vh;
      display: flex; flex-direction: column; align-items: center; justify-content: flex-start;
      padding: 110px 28px 0;
      position: relative; overflow: hidden; text-align: center;
    }
    .hero::after {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 90% 55% at 50% 0%, var(--green-glow2) 0%, transparent 60%),
        radial-gradient(ellipse 50% 30% at 20% 80%, var(--green-glow) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-inner { max-width: 860px; width: 100%; position: relative; z-index: 1; }
    .hero-eyebrow {
      font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.2em;
      color: var(--green); margin-bottom: 1.8rem;
      display: flex; align-items: center; justify-content: center; gap: 8px; opacity: .85;
    }
    .hero h1 { margin-bottom: 1.5rem; }
    .hero h1 em { font-style: normal; color: var(--green); }
    .hero-sub {
      font-size: 1.15rem; line-height: 1.8; color: var(--text-muted);
      margin: 0 auto 2.6rem; max-width: 620px;
    }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
    .install-block {
      margin-top: 3rem;
      display: inline-flex; flex-direction: column; align-items: flex-start; gap: 10px;
      width: 100%; max-width: 520px;
    }
    .install-pm {
      display: flex; gap: 4px;
    }
    .install-pm-btn {
      padding: 4px 14px; border-radius: 20px;
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.03em;
      background: transparent; color: var(--text-muted);
      border: 1px solid var(--border); cursor: pointer; transition: all .15s;
    }
    .install-pm-btn.active { background: var(--green); color: #fff; border-color: var(--green); }
    .install-distro {
      display: none; gap: 4px;
    }
    .install-distro.visible { display: flex; }
    .install-distro-btn {
      padding: 3px 10px; border-radius: 20px;
      font-size: 0.68rem; color: var(--text-muted);
      background: transparent; border: 1px solid var(--border);
      cursor: pointer; transition: all .15s;
    }
    .install-distro-btn.active { color: var(--green); border-color: var(--green); }
    .install-shell {
      display: flex; align-items: center; gap: 12px;
      background: var(--bg-surface); border: 1px solid var(--border-bright);
      border-radius: var(--r); padding: 14px 20px; width: 100%;
    }
    .install-dollar { font-family: var(--mono); font-size: 0.9rem; color: var(--text-muted); user-select: none; }
    .install-cmd    { font-family: var(--mono); font-size: 0.9rem; color: var(--text); flex: 1; text-align: left; overflow-x: auto; white-space: nowrap; scrollbar-width: none; }
    .install-cmd::-webkit-scrollbar { display: none; }
    .install-copy {
      background: none; border: none; cursor: pointer; padding: 2px;
      color: var(--text-muted); transition: color .15s; line-height: 1; flex-shrink: 0;
    }
    .install-copy:hover { color: var(--green); }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 13px 26px; border-radius: var(--r);
      font-weight: 600; font-size: 0.92rem;
      cursor: pointer; transition: all .18s; text-decoration: none !important;
    }
    .btn-primary  { background: var(--green); color: #ffffff; }
    .btn-primary:hover  { background: var(--green-dim); transform: translateY(-1px); }
    .btn-secondary {
      background: transparent; color: var(--text); border: 1px solid var(--border-bright);
    }
    .btn-secondary:hover { border-color: var(--green-faint); color: var(--green); background: var(--green-glow); }

    /* ── FLEET GRID ── */
    .fleet-wrap {
      width: 100%; max-width: 1140px;
      margin: 80px auto 0; padding: 0 28px;
      position: relative; z-index: 1;
    }
    .fleet-header {
      display: flex; align-items: center; gap: 16px; margin-bottom: 12px;
      font-family: var(--mono); font-size: 0.72rem;
    }
    #fleet-trusted { color: var(--green); font-weight: 700; letter-spacing: .04em; }
    #fleet-status  { font-weight: 700; letter-spacing: .04em; color: #f5c43c; }
    .fleet-sep  { color: var(--text-dim); }
    .fleet-meta { color: var(--text-dim); }
    .fleet-grid { display: grid; grid-template-columns: repeat(24, 1fr); gap: 5px; }
    .fn {
      aspect-ratio: 1; border-radius: 3px;
      border: 1px solid var(--border); background: var(--bg-card);
      transition: background .35s, border-color .35s, box-shadow .35s;
    }
    .fn.trusted  { border-color: rgba(37,99,255,.28); background: rgba(37,99,255,.07); box-shadow: 0 0 5px rgba(37,99,255,.1); }
    .fn.verifying{ border-color: rgba(245,196,60,.4); background: rgba(245,196,60,.07); animation: fn-verify .85s ease-in-out infinite; }
    .fn.failed   { border-color: rgba(255,50,70,.5); background: rgba(255,30,60,.1); box-shadow: 0 0 8px rgba(255,40,70,.18); }
    @keyframes fn-verify {
      0%,100% { box-shadow: 0 0 3px rgba(245,196,60,.15); }
      50%      { box-shadow: 0 0 10px rgba(245,196,60,.35); }
    }
    .fleet-fade {
      height: 56px;
      background: linear-gradient(to bottom, transparent, var(--bg));
      margin-top: -56px; position: relative; z-index: 2; pointer-events: none;
    }

    /* ── DIVIDER ── */
    .divider { border: none; border-top: 1px solid var(--border); margin: 0; }

    /* ── SVG icon helpers ── */
    .ico { display: inline-flex; align-items: center; justify-content: center; color: var(--green); }
    .ico svg { display: block; }
    .ico-muted { color: var(--text-muted); }

    /* ── PROBLEM ── */
    .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
    .problem-lead { font-size: 1.05rem; line-height: 1.8; }
    .problem-lead strong { color: var(--text); }
    .trust-chain {
      display: flex; flex-direction: column;
      border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden;
    }
    .chain-layer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.75rem 1.1rem;
      border-left: 2px solid transparent;
      border-bottom: 1px solid var(--border);
      transition: background .2s;
    }
    .chain-layer:last-child { border-bottom: none; }
    .chain-layer:nth-child(1) { border-left-color: rgba(37,99,255,0.25); }
    .chain-layer:nth-child(2) { border-left-color: rgba(37,99,255,0.38); background: rgba(37,99,255,0.015); }
    .chain-layer:nth-child(3) { border-left-color: rgba(37,99,255,0.55); background: rgba(37,99,255,0.025); }
    .chain-layer:nth-child(4) { border-left-color: rgba(37,99,255,0.72); background: rgba(37,99,255,0.035); }
    .chain-root {
      border-left: 3px solid var(--green) !important;
      background: rgba(37,99,255,0.06) !important;
    }
    .chain-name { font-size: 0.87rem; font-weight: 500; color: var(--text); }
    .chain-root .chain-name { color: var(--green); font-weight: 600; }
    .chain-root-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--green); opacity: 0.6; }

    /* ── FEATURES ── */
    .section-header { text-align: center; max-width: 640px; margin: 0 auto 64px; }
    .section-header p { margin-top: 1rem; font-size: 1rem; }
    .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .feature-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--r-lg); padding: 28px;
      transition: border-color .2s, background .2s, transform .2s;
    }
    .feature-card:hover { border-color: rgba(37,99,255,.2); background: var(--bg-card-hov); transform: translateY(-2px); }
    .feature-icon {
      width: 42px; height: 42px;
      background: var(--green-glow); border: 1px solid rgba(37,99,255,.15);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      color: var(--green);
      margin-bottom: 16px;
    }
    .feature-card h3 { font-size: 0.95rem; color: var(--text); margin-bottom: 8px; }
    .feature-card p  { font-size: 0.85rem; line-height: 1.65; }

    /* ── HOW IT WORKS ── */
    .hiw-bg { background: var(--bg); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    /* section glow accents */
    .glow-right { position: relative; }
    .glow-right::after { content:''; position:absolute; inset:0; background: radial-gradient(ellipse 55% 60% at 80% 50%, rgba(37,99,255,.07) 0%, transparent 70%); pointer-events:none; z-index:0; }
    .glow-center { position: relative; }
    .glow-center::after { content:''; position:absolute; inset:0; background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(37,99,255,.07) 0%, transparent 70%); pointer-events:none; z-index:0; }
    .glow-left { position: relative; }
    .glow-left::after { content:''; position:absolute; inset:0; background: radial-gradient(ellipse 55% 60% at 20% 50%, rgba(37,99,255,.07) 0%, transparent 70%); pointer-events:none; z-index:0; }
    .steps { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0; position: relative; max-width: 1060px; margin: 0 auto; }
    .steps::before {
      content: ''; position: absolute; top: 29px; left: 10%; width: 80%; height: 1px;
      background: linear-gradient(90deg, transparent, var(--border-bright) 20%, var(--border-bright) 80%, transparent);
    }
    .step { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 0 14px; position: relative; }
    .step-num {
      width: 58px; height: 58px; border-radius: 50%;
      background: var(--bg-card); border: 1px solid var(--border-bright);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--mono); font-size: 0.75rem; font-weight: 700; color: var(--green);
      margin-bottom: 18px; position: relative; z-index: 1;
    }
    .step-num.active { background: var(--green-glow); border-color: rgba(37,99,255,.35); box-shadow: 0 0 22px rgba(37,99,255,.15); }
    .step h3    { font-size: 0.85rem; color: var(--text); margin-bottom: 8px; letter-spacing: 0; }
    .step p     { font-size: 0.78rem; color: var(--text-dim); line-height: 1.55; }
    .step-detail { font-family: var(--mono); font-size: 0.65rem; color: var(--green-faint); margin-top: 8px; }

    /* ── USE CASES ── */
    .usecases-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
    .usecase-card {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg);
      padding: 30px; display: flex; flex-direction: column; gap: 14px;
      transition: border-color .22s, transform .2s;
    }
    .usecase-card:hover { border-color: rgba(37,99,255,.2); transform: translateY(-3px); }
    .usecase-label { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); font-weight: 600; }
    .usecase-card h3 { font-size: 1.1rem; color: var(--text); }
    .usecase-card p  { font-size: 0.85rem; line-height: 1.7; flex: 1; }
    .compliance-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
    .ctag { font-family: var(--mono); font-size: 0.62rem; color: var(--text-dim); background: var(--bg-surface); border: 1px solid var(--border); border-radius: 4px; padding: 3px 7px; letter-spacing: 0.05em; }

    /* ── TRUST CHAIN ── */
    .chain-bg { background: var(--bg-surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); overflow: hidden; }
    .chain-intro { text-align: center; margin-bottom: 52px; }
    .chain-intro p { margin-top: .8rem; font-size: .95rem; max-width: 560px; margin-left: auto; margin-right: auto; }
    .chain-row { display: flex; align-items: center; overflow-x: auto; padding-bottom: 12px; scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
    .chain-node { flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; text-align: center; min-width: 104px; padding: 0 5px; }
    .chain-box {
      background: var(--bg-card); border: 1px solid var(--border-bright); border-radius: var(--r);
      padding: 12px 8px 10px; width: 100%;
      display: flex; flex-direction: column; align-items: center;
      transition: border-color .2s, box-shadow .2s;
    }
    .chain-box:hover { border-color: rgba(37,99,255,.3); box-shadow: 0 0 16px var(--green-glow); }
    .chain-box-icon  { color: var(--text-muted); margin-bottom: 6px; }
    .chain-box-label { font-family: var(--mono); font-size: 0.6rem; font-weight: 700; color: var(--text-muted); letter-spacing: .06em; line-height: 1.3; }
    .chain-box-sub   { font-size: 0.58rem; color: var(--text-dim); margin-top: 3px; line-height: 1.3; text-align: center; }
    .chain-arrow     { flex: 0 0 auto; color: var(--green-faint); font-size: .9rem; padding: 0 3px; position: relative; top: -8px; }
    .chain-legend { display: flex; justify-content: center; gap: 28px; margin-top: 38px; flex-wrap: wrap; }
    .chain-legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.78rem; color: var(--text-muted); }
    .chain-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); }

    /* ── STANDARDS ── */
    .standards-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 44px; }
    .std-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 22px; text-align: center; display: block; text-decoration: none !important; color: inherit; transition: border-color .18s, box-shadow .18s; }
    .std-card:hover { border-color: rgba(37,99,255,.35); box-shadow: 0 0 18px rgba(37,99,255,.08); }
    .std-icon  { display: flex; align-items: center; justify-content: center; color: var(--green); margin-bottom: 12px; }
    .std-name  { font-weight: 700; font-size: 0.9rem; color: var(--text); margin-bottom: 6px; }
    .std-desc  { font-size: 0.78rem; color: var(--text-muted); line-height: 1.55; }

    /* ── CTA ── */
    .cta-section { text-align: center; padding: 100px 24px; position: relative; overflow: hidden; }
    .cta-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(37,99,255,.07) 0%, transparent 70%); pointer-events: none; }
    .cta-section h2 { margin-bottom: 1rem; }
    .cta-section p  { max-width: 480px; margin: 0 auto 2.4rem; font-size: 1rem; }
    .cta-actions    { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
    .cta-email { margin-top: 1.8rem; }
    .cta-email a {
      display: inline-block;
      font-family: var(--mono); font-size: 0.9rem;
      color: var(--green); border: 1px solid var(--green);
      padding: 10px 22px; border-radius: var(--r);
      text-decoration: none; transition: background .18s, color .18s;
    }
    .cta-email a:hover { background: var(--green); color: #000; }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--border); padding: 34px 28px; }
    .footer-inner { max-width: 1140px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 14px; }
    .footer-logo { font-weight: 800; font-size: 0.95rem; letter-spacing: -0.02em; }
    .footer-logo .rat  { color: var(--green); }
    .footer-logo .rest { color: var(--text-muted); }
    .footer-links { display: flex; gap: 22px; }
    .footer-links a { font-size: 0.8rem; color: var(--text-dim); text-decoration: none; }
    .footer-links a:hover { color: var(--text-muted); }
    .footer-right { font-size: 0.75rem; color: var(--text-dim); font-family: var(--mono); }

    /* ── SCROLL REVEAL ── */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity .55s ease, transform .55s ease; }
    .reveal.in-view { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .problem-grid   { grid-template-columns: 1fr; gap: 40px; }
      .features-grid  { grid-template-columns: 1fr 1fr; }
      .steps          { grid-template-columns: 1fr 1fr; gap: 26px; }
      .steps::before  { display: none; }
      .usecases-grid  { grid-template-columns: 1fr; }
      .standards-grid { grid-template-columns: 1fr 1fr; }
      .nav-links      { display: none; }
      .fleet-grid     { grid-template-columns: repeat(12, 1fr); }
    }
    @media (max-width: 600px) {
      .features-grid  { grid-template-columns: 1fr; }
      .standards-grid { grid-template-columns: 1fr; }
      .steps          { grid-template-columns: 1fr; }
      .fleet-grid     { grid-template-columns: repeat(8, 1fr); }
      h1              { font-size: 2.4rem; }
    }
  </style>
</head>
